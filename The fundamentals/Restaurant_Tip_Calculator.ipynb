   "source": [
    "bill = float(input(\"Bill amount: \"))\n",
    "tip_percent = float(input(\"Tip %: \"))\n",
    "\n",
    "tip_amount = bill * (tip_percent / 100)\n",
    "total = bill + tip_amount\n",
    "\n",
    "print(f\"Tip:   ${tip_amount:.2f}\")\n",
    "print(f\"Total: ${total:.2f}\")"
   ]
